# Docker image to run
IMAGE=ghcr.io/yfxu/picpan:latest

# Port to expose on the host
PORT=3000

# Required — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://your-domain.com

# Database
# - External DB: set DATABASE_URL to your connection string
# - Local Postgres (docker-compose.postgres.yml): leave blank, set POSTGRES_* below
DATABASE_URL=

# Local Postgres only (ignored when using an external database)
POSTGRES_USER=picpan
POSTGRES_PASSWORD=
POSTGRES_DB=picpan
